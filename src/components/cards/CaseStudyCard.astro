---
interface Props {
  index: number;
  title: string;
  summary: string;
  tags: string[];
  slug: string;
}

const { index, title, summary, tags, slug } = Astro.props;
const sequenceNumber = String(index + 1).padStart(2, '0');
---

<a
  href={`/case-study/${slug}`}
  class="group block p-6 tablet:p-8 bg-surface border border-border rounded-lg hover:-translate-y-1 hover:shadow-lg hover:shadow-accent/5 transition-all duration-150 ease-out"
>
  <span class="text-h1 font-display font-semibold text-text-muted/20 select-none" aria-hidden="true">
    {sequenceNumber}
  </span>
  <h3 class="mt-2 text-h3 font-display font-semibold text-text-primary group-hover:text-accent transition-colors">
    {title}
  </h3>
  <p class="mt-2 text-body-small text-text-secondary line-clamp-2">
    {summary}
  </p>
  <div class="mt-4 flex gap-2 flex-wrap">
    {tags.map((tag) => (
      <span class="px-2 py-1 text-caption text-text-muted bg-background rounded-md border border-border">
        {tag}
      </span>
    ))}
  </div>
</a>
