---
import { NAV_LINKS, SITE_CONFIG } from '@/config/site';
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-40 transition-colors duration-200"
>
  <nav
    class="mx-auto max-w-content px-6 tablet:px-12 desktop:px-16 h-16 flex items-center justify-between"
    aria-label="Main navigation"
  >
    <!-- Name / Logo -->
    <a href="/" class="font-display text-body font-semibold text-text-primary hover:text-accent transition-colors">
      {SITE_CONFIG.name}
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden tablet:flex items-center gap-8">
      <span class="flex items-center gap-2 text-caption text-text-muted">
        <span class="inline-block w-2 h-2 rounded-full bg-success animate-pulse" aria-hidden="true"></span>
        Available for work
      </span>
      {NAV_LINKS.map((link) =>
        link.isCta ? (
          <a
            href={link.href}
            class="inline-flex items-center justify-center px-5 py-2 bg-accent hover:bg-accent-hover text-white text-body-small font-medium rounded-md transition-colors min-h-[44px] min-w-[44px]"
          >
            {link.label}
          </a>
        ) : (
          <a
            href={link.href}
            class="text-body-small text-text-secondary hover:text-text-primary transition-colors min-h-[44px] min-w-[44px] flex items-center"
          >
            {link.label}
          </a>
        )
      )}
    </div>

    <!-- Mobile: Contact CTA + Hamburger -->
    <div class="flex tablet:hidden items-center gap-3">
      <a
        href="#contact"
        class="inline-flex items-center justify-center px-4 py-2 bg-accent hover:bg-accent-hover text-white text-caption font-medium rounded-md transition-colors min-h-[44px]"
      >
        Contact
      </a>
      <button
        id="hamburger-btn"
        type="button"
        class="flex items-center justify-center w-11 h-11 text-text-primary"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open main menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-50 bg-background/95 backdrop-blur-lg flex flex-col items-center justify-center gap-8 transition-opacity duration-200 opacity-0 pointer-events-none"
    role="dialog"
    aria-modal="true"
    aria-label="Mobile navigation"
  >
    <button
      id="close-menu-btn"
      type="button"
      class="absolute top-4 right-6 flex items-center justify-center w-11 h-11 text-text-primary"
      aria-label="Close main menu"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <span class="flex items-center gap-2 text-body-small text-text-muted mb-4">
      <span class="inline-block w-2 h-2 rounded-full bg-success animate-pulse" aria-hidden="true"></span>
      Available for work
    </span>

    {NAV_LINKS.map((link) => (
      <a
        href={link.href}
        class="mobile-nav-link text-h2 font-display font-semibold text-text-primary hover:text-accent transition-colors min-h-[44px] flex items-center"
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<!-- Spacer to prevent content from hiding behind fixed nav -->
<div class="h-16" aria-hidden="true"></div>

<script>
  const nav = document.getElementById('site-nav');
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const closeMenuBtn = document.getElementById('close-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = mobileMenu?.querySelectorAll('.mobile-nav-link');

  // Glassmorphism on scroll via IntersectionObserver
  const sentinel = document.createElement('div');
  sentinel.style.position = 'absolute';
  sentinel.style.top = '0';
  sentinel.style.height = '1px';
  sentinel.style.width = '1px';
  document.body.prepend(sentinel);

  const observer = new IntersectionObserver(
    ([entry]) => {
      if (!entry.isIntersecting) {
        nav?.classList.add('bg-background/80', 'backdrop-blur-xl', 'border-b', 'border-border');
      } else {
        nav?.classList.remove('bg-background/80', 'backdrop-blur-xl', 'border-b', 'border-border');
      }
    },
    { threshold: 1.0 }
  );
  observer.observe(sentinel);

  // Mobile menu toggle
  function openMenu() {
    mobileMenu?.classList.remove('opacity-0', 'pointer-events-none');
    mobileMenu?.classList.add('opacity-100', 'pointer-events-auto');
    hamburgerBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    closeMenuBtn?.focus();
  }

  function closeMenu() {
    mobileMenu?.classList.add('opacity-0', 'pointer-events-none');
    mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto');
    hamburgerBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    hamburgerBtn?.focus();
  }

  hamburgerBtn?.addEventListener('click', openMenu);
  closeMenuBtn?.addEventListener('click', closeMenu);

  // Close on link click
  mobileLinks?.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu?.classList.contains('opacity-100')) {
      closeMenu();
    }
  });

  // Focus trap inside mobile menu
  mobileMenu?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab') return;
    const focusable = mobileMenu.querySelectorAll<HTMLElement>(
      'a[href], button, [tabindex]:not([tabindex="-1"])'
    );
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });
</script>
