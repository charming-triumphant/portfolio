---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page not found" description="This page doesn't exist. But I do.">
  <section class="min-h-[60vh] flex flex-col items-center justify-center px-6 text-center">
    <p class="text-display font-display font-semibold text-text-muted/20 select-none" aria-hidden="true">
      404
    </p>
    <h1 class="text-h1 font-display font-semibold text-text-primary mt-4">
      Well, this page doesn't exist — but I do.
    </h1>
    <p class="text-body text-text-secondary mt-4 max-w-lg">
      You've wandered somewhere that doesn't have anything yet.
      Let's get you back to somewhere that does.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center justify-center px-6 py-3 bg-accent hover:bg-accent-hover text-white text-body-small font-medium rounded-md transition-colors min-h-[44px]"
    >
      Back to homepage
    </a>
  </section>
</BaseLayout>
