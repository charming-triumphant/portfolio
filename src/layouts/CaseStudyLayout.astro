---
import BaseLayout from '@/layouts/BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    summary: string;
    date: Date;
    tags: string[];
  };
}

const { frontmatter } = Astro.props;
const formattedDate = new Intl.DateTimeFormat('en-NZ', {
  year: 'numeric',
  month: 'long',
}).format(frontmatter.date);
---

<BaseLayout
  title={`${frontmatter.title} — Case Study`}
  description={frontmatter.summary}
  type="article"
>
  <article class="py-space-12 px-6 tablet:px-12 desktop:px-16">
    <div class="mx-auto max-w-3xl">
      <!-- Header -->
      <header class="mb-space-8">
        <a
          href="/#work"
          class="inline-flex items-center gap-2 text-caption text-text-muted hover:text-accent transition-colors mb-space-4"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Back to work
        </a>
        <h1 class="text-h1 font-display font-semibold text-text-primary">
          {frontmatter.title}
        </h1>
        <p class="mt-3 text-body text-text-secondary">
          {frontmatter.summary}
        </p>
        <div class="mt-4 flex items-center gap-4 flex-wrap">
          <time class="text-caption text-text-muted" datetime={frontmatter.date.toISOString()}>
            {formattedDate}
          </time>
          <div class="flex gap-2 flex-wrap">
            {frontmatter.tags.map((tag: string) => (
              <span class="px-2 py-1 text-caption text-text-muted bg-surface rounded-md border border-border">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </header>

      <!-- Content -->
      <div class="prose prose-invert prose-zinc max-w-none
        prose-headings:font-display prose-headings:font-semibold prose-headings:text-text-primary
        prose-h2:text-h2 prose-h2:mt-space-8 prose-h2:mb-space-4
        prose-h3:text-h3 prose-h3:mt-space-6 prose-h3:mb-space-3
        prose-p:text-body prose-p:text-text-secondary prose-p:leading-relaxed
        prose-li:text-body prose-li:text-text-secondary
        prose-strong:text-text-primary prose-strong:font-semibold
        prose-code:font-mono prose-code:text-accent prose-code:bg-surface prose-code:px-1 prose-code:py-0.5 prose-code:rounded
        prose-a:text-accent prose-a:no-underline hover:prose-a:underline
        prose-blockquote:border-accent prose-blockquote:text-text-secondary
      ">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
